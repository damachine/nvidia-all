        fi
      fi

      # 6.8
      if [ "$_kernel68" = "1" ]; then
        patchy=0
        for yup in "${_whitelist68[@]}"; do
          [[ $pkgver = $yup ]] && patchy=1
        done
        if [ "$patchy" = "1" ]; then
          msg2 "Applying kernel-6.8.patch for dkms..."
          patch -Np1 -i "${_where}/kernel-6.8.patch"
        else
          msg2 "Skipping kernel-6.8.patch as it doesn't apply to this driver version..."
        fi
      fi

      # 6.11
      if (( $(vercmp "$_kernel" "6.11") >= 0 )); then
        if [[ $pkgver = 560.* ]]; then
          # enable modeset/fbdev by default
          msg2 "Applying make-modeset-fbdev-default.diff for dkms..."
          patch -Np1 -i "${_where}/make-modeset-fbdev-default.diff"
          # fix fbdev phantom monitor (6.11)
          msg2 "Applying 6.11-fbdev.diff for dkms..."
          patch -Np1 -i "${_where}/6.11-fbdev.diff"
        elif [[ $pkgver = 565.* ]]; then
          # enable modeset/fbdev by default
          msg2 "Applying make-modeset-fbdev-default-565.diff for dkms..."
          patch -Np1 -i "${_where}/make-modeset-fbdev-default-565.diff"
        fi
      fi

      # 6.12
      if [ "$_kernel612" = "1" ]; then
        patchy=0
        for yup in "${_whitelist612[@]}"; do
          [[ $pkgver = $yup ]] && patchy=1
        done
        if [ "$patchy" = "1" ]; then
          msg2 "Applying kernel-6.12.patch for dkms..."
          patch -Np1 -i "${_where}/kernel-6.12.patch"
        else
          msg2 "Skipping kernel-6.12.patch as it doesn't apply to this driver version..."
        fi
      fi

      # 6.19
      if (( $(vercmp "$_kernel" "6.19") >= 0 )); then
        if [[ $pkgver = 470* ]]; then
          cd "$srcdir"/"$_pkg"/kernel-dkms
          msg2 "Applying kernel-6.19-470.patch for $_kernel..."
          patch -Np1 -i "${_where}/kernel-6.19-470.patch"
        fi
      fi

      # 7.0
      if (( $(vercmp "$_kernel" "7.0") >= 0 )); then
        if [[ $pkgver = 470* ]]; then
          cd "$srcdir"/"$_pkg"/kernel-dkms
          msg2 "Applying kernel-7.0-470.patch for $_kernel..."
          patch -Np1 -i "${_where}/kernel-7.0-470.patch"
        fi
      fi

      if [ "$_gcc14" = "true" ]; then
        msg2 "Applying gcc-14 patch..."
        if [[ $pkgver = 470* ]]; then
          patch -Np1 -i "${_where}/gcc-14-470.diff"
        else
          patch -Np1 -i "${_where}/gcc-14.diff"
        fi
      fi

      if [ "$_gcc15" = "true" ]; then
        msg2 "Applying gcc-15 patch..."
        patch -Np1 -i "${_where}/gcc-15.diff"
      fi

      # Legacy quirks
      if [ "$_oldstuff" = "1" ]; then
        msg2 "Applying 01-ipmi-vm.diff for dkms..."
        patch -Np1 -i "${_where}/01-ipmi-vm.diff"
      fi
      if [ "$_youngeryetoldstuff" = "1" ]; then
        msg2 "Applying 02-ipmi-vm.diff for dkms..."
        patch -Np1 -i "${_where}/02-ipmi-vm.diff"
      fi
      if [[ $pkgver = 396* ]] || [[ $pkgver = 410* ]] || [[ $pkgver = 415* ]] || [[ $pkgver = 418.* ]] || [[ $pkgver = 430.0* ]] || [[ $pkgver = 435.* ]] || [[ $pkgver = 440.2* ]] || [[ $pkgver = 440.3* ]] || [[ $pkgver = 440.43.* ]] || [[ $pkgver = 440.44 ]] && [ "$_54_prime" = "true" ]; then
        msg2 "Applying kernel-5.4-prime.diff for dkms..."
        patch -Np1 -i "${_where}/kernel-5.4-prime.diff"
      fi
    fi
  fi
}

_nv_build() {
  if [ "$_libxnvctrl" = "true" ]; then
    cd "$srcdir/nvidia-settings-$pkgver"
    make -C src PREFIX=/usr NV_USE_BUNDLED_LIBJANSSON=0 OUTPUTDIR=out out/libXNVCtrl.so
    cd "$srcdir"
  fi

  if [ "${_build_utils_package_only:-false}" = "true" ]; then
    msg2 "_build_utils_package_only=true - skipping kernel module build steps."
    return 0
  fi

  # skip for DKMS
  if [ "$_dkms" = "true" ]; then
    msg2 "_dkms=true - skipping kernel module build steps (handled by DKMS)."
    return 0
  fi

  if [ "$_open_source_modules" = "true" ]; then
    cd "${_srcbase}-${pkgver}"

    # per-kernel output dirs
    rm -rf "$srcdir/open-kmods"
    mkdir -p "$srcdir/open-kmods"
  fi

  local _kernel
  local -a _kernels
  mapfile -t _kernels < <(_detect_kernels)

  for _kernel in "${_kernels[@]}"; do
    _build_flags "$_kernel"

    local MODULE_FLAGS=(
      IGNORE_CC_MISMATCH=yes
      SYSSRC="/usr/lib/modules/$_kernel/build"
    )

    local _label="Nvidia"
    if [ "$_open_source_modules" = "true" ]; then
      _label="open NVIDIA"
    else
      cd "$srcdir"/$_pkg/kernel-$_kernel
    fi

    msg2 "Building $_label module for $_kernel..."
    CFLAGS= CXXFLAGS= LDFLAGS= make -j"$(nproc)" "${BUILD_FLAGS[@]}" "${MODULE_FLAGS[@]}" modules |& tee -a "$_where"/logs/build.log.txt

    if [ "$_open_source_modules" = "true" ]; then
      local _open_kmods_dir="$srcdir/open-kmods/$_kernel"
      mkdir -p "$_open_kmods_dir"
      install -m644 -t "$_open_kmods_dir" kernel-open/*.ko
    fi
  done
}

# Clean on exit
function exit_cleanup {
  # Remove all flat-copied files from nvidia-all-patches/ and nvidia-all-config/system/
  rm -f "${_where}"/*.diff
  rm -f "${_where}"/*.patch
  rm -f "${_where}"/*.conf
  rm -f "${_where}"/*.rules
  rm -f "${_where}"/*.sh
  rm -f "${_where}"/*.hook
  rm -f "${_where}"/*.install
  rm -f "${_where}"/*.dinit
  rm -f "${_where}"/*.sysusers
  rm -f "${_where}/cuda-no-stable-perf-limit"
  rm -f "${_where}/limit-vram-usage"
  rm -rf "${_where}/egl-wayland"

  # Remove state tracker
  rm -f "$_where"/BIG_UGLY_FROGMINER

  # move built packages to versioned dir
  if [ "${_local_package_storing:-}" = "true" ]; then
    rm -rf "${_where}/${pkgver}-packages" && \
      mkdir -p "${_where}/${pkgver}-packages" && \
      mv "${_where}/"*.pkg.* "${_where}/${pkgver}-packages"/ >/dev/null 2>&1
  fi

  # Ensure logs dir exists in case of early failure before _nv_srcprep
  mkdir -p "${_where}/logs"

  # Copy customization.cfg snapshot to logs
  [[ -f "${_where}/customization.cfg" ]] && \
    cp -f "${_where}/customization.cfg" "${_where}/logs/customization.cfg.txt"

  # Move shell-output.log to logs and strip ANSI escape codes
  if [[ -f "${_where}/shell-output.log" ]]; then
    mv -f "${_where}/shell-output.log" "${_where}/logs/shell-output.log.txt"
    sed -i 's/\x1b\[[0-9;]*m//g' "${_where}/logs/shell-output.log.txt"
    sed -i 's/\x1b(B//g' "${_where}/logs/shell-output.log.txt"
  fi

  # Create logs/system-info.txt
  {
    cat /etc/os-release
    echo "#################"
    echo "NVIDIA driver: ${_driver_version:-unknown} (${_driver_branch:-unknown})"
    echo "#################"
    gcc -v 2>&1
    if command -v clang &>/dev/null; then
      echo "#################"
      clang -v 2>&1
    fi
  } > "${_where}/logs/system-info.txt"

  remove_deps || ( true && msg2 "remove_deps not found" )

  msg2 'exit cleanup done'
}

trap exit_cleanup EXIT
